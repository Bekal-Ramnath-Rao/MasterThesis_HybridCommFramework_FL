<?xml version="1.0" encoding="UTF-8"?>
<!-- CycloneDDS MACVLAN client 2: static peer to server (IP matches docker-compose-emotion.macvlan.yml) -->
<CycloneDDS>
  <Domain id="0">
    <General>
      <Interfaces>
        <NetworkInterface name="eth0" multicast="false" autodetermine="false"/>
      </Interfaces>
    </General>
    <Discovery>
      <Peers>
        <Peer address="192.168.254.10:7410"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
