# Copy this file to `.privileged_ops.env` in the same folder and fill in your values.
# The GUI reads `.privileged_ops.env` at runtime and exports these keys to experiment scripts.
# Keep the real `.privileged_ops.env` file local to each machine.

# Informational only for now; native sudo operations use the password of the user who launched the GUI.
FL_SUDO_USERNAME=your_linux_username

# Used by native namespace experiments that call `sudo -S ...`.
FL_SUDO_PASSWORD=your_linux_password
