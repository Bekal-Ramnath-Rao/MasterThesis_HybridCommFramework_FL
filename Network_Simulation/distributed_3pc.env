# ============================================================
# 3-PC Distributed FL Experiment — Environment Variables
# ============================================================
# Network layout:
#   192.168.0.102  →  Server PC (Ubuntu) — runs server + client 1 locally
#   192.168.0.100  →  Windows PC         — runs client 2 via distributed_client_gui.py
#   192.168.0.101  →  Linux PC           — runs client 3 via distributed_client_gui.py
#
# Usage on the SERVER PC (192.168.0.102) before launching the experiment:
#   source Network_Simulation/distributed_3pc.env
#   python Network_Simulation/run_network_experiments.py \
#       --use-case emotion --rounds 10 \
#       --local-clients 1 --min-clients 3 \
#       --network-mode host --single --protocol mqtt --scenario dynamic
#
# Then on each remote PC, launch distributed_client_gui.py (the defaults in the GUI
# are already set to these IPs after the latest code update).
# ============================================================

# ----- FL Federation sizing -----
export NUM_CLIENTS=3
export MIN_CLIENTS=3
export NUM_ROUNDS=10

# ----- Server / broker host (used by remote clients) -----
export UNIFIED_FL_SERVER_HOST=192.168.0.102

# ----- DDS static unicast peers (all protocols that use DDS, including rl_unified) -----
# Server and client1 share the server machine (192.168.0.102).
export DDS_PEER_SERVER=192.168.0.102
export DDS_PEER_CLIENT1=192.168.0.102
export DDS_PEER_CLIENT2=192.168.0.100
export DDS_PEER_CLIENT3=192.168.0.101

# SPDP_* can optionally differ from PEER_* (e.g. for Docker bridge → LAN routing).
# Leave empty to fall back to the PEER_* values (recommended for host-network mode).
export DDS_SPDP_SERVER=
export DDS_SPDP_CLIENT1=
export DDS_SPDP_CLIENT2=
export DDS_SPDP_CLIENT3=

# ----- DDS distributed mode: MUST be empty so dds_distributed_unicast.py generates the XML -----
# Do NOT set CYCLONEDDS_URI when running in distributed 3-PC mode.
export CYCLONEDDS_URI=

# ----- Protocol-specific broker / server endpoints -----
# (used by single-protocol compose when server is on 192.168.0.102)
export MQTT_BROKER=192.168.0.102
export MQTT_PORT=1883
export AMQP_HOST=192.168.0.102
export AMQP_PORT=5672
export GRPC_HOST=192.168.0.102
export GRPC_PORT=50051
export QUIC_HOST=192.168.0.102
export QUIC_PORT=4433
export HTTP3_HOST=192.168.0.102
export HTTP3_PORT=4434

# ----- Network scenario (override per experiment run) -----
export NETWORK_SCENARIO=dynamic

# ----- Termination -----
export STOP_ON_CLIENT_CONVERGENCE=true
export TRAINING_TERMINATION_MODE=

# ----- RL Unified specific -----
export USE_RL_SELECTION=true
export USE_COMMUNICATION_MODEL_REWARD=true
export USE_QL_CONVERGENCE=false
export USE_RL_EXPLORATION=true
export RL_BOUNDARY_PIPELINE=true
export RL_PHASE0_ROUNDS=20
export RESET_EPSILON=true

# ----- Quantization (off by default) -----
export USE_QUANTIZATION=false
export QUANTIZATION_BITS=8
export QUANTIZATION_STRATEGY=ptq
